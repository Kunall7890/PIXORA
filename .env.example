# Pixora Creative Engine - Environment Configuration

# ==================== API Keys ====================

# Groq API Key (Free tier: https://console.groq.com)
# Use Llama 3.3 70B model
GROQ_API_KEY=your_groq_api_key_here

# Together AI API Key (Optional - for image generation)
TOGETHER_AI_API_KEY=your_together_ai_key_here

# Replicate API Token (Optional - for video generation)
# Sign up at https://replicate.com
REPLICATE_API_TOKEN=your_replicate_token_here

# Hugging Face API Key (Optional - for model access)
HUGGINGFACE_API_KEY=your_huggingface_key_here

# ==================== Redis Configuration ====================

# Redis connection for task queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== Application Settings ====================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ==================== Feature Flags ====================

# Set to true to use local GPU (requires CUDA/PyTorch)
USE_LOCAL_GPU=false

# Set to true to enable video generation (requires Replicate)
ENABLE_VIDEO_GENERATION=true

# Set to true to enable advanced image generation
ENABLE_ADVANCED_IMAGES=false
